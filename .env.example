PRIVATE_KEY=0xYourPrivatekey

RAW_AMOUNT=1000000000000000000
SLIPPAGE=0.005 # 0.005 is for 0.5% slippage

# ============================================================================
# Normal flow (bridge-pt-swap-bridge-back)
# ============================================================================

A_RPC_URL=https://your-spoke-chain-rpc-url
A_OFT=0xYourPtOftToken
A_TOKEN=0xYourToken

B_RPC_URL=https://your-hub-chain-rpc-url
B_TOKEN=0xYourToken
B_MARKET=0xMarketAddress # required for bridge-pt-swap-bridge-back --version=2

# ============================================================================
# Cross-chain swap flow (cross-chain-swap)
# ============================================================================

SOURCE_RPC_URL=https://your-source-chain-rpc-url
SOURCE_TOKEN_IN=0xYourTokenIn

HUB_RPC_URL=https://your-hub-chain-rpc-url
HUB_MARKET=0xYourMarketAddress

DESTINATION_RPC_URL=https://your-destination-chain-rpc-url
DESTINATION_TOKEN_OUT=0xYourTokenOut

BRIDGE_ROUTE_PRIORITY=BEST_RETURN # optional, defaults to BEST_RETURN. options: BEST_RETURN, FASTEST
PENDLE_API_BASE_URL=https://api-v2.pendle.finance/core # optional, defaults to this value
